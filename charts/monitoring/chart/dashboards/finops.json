        "legend": { "calcs": ["lastNotNull", "mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (namespace) (container_memory_working_set_bytes{container!=\"\", container!=\"POD\"}) / 1024 / 1024 / 1024 * on() group_left() ((count(kube_node_labels{label_workload=~\"control-plane|monitoring\"}) * 0.0456 + count(kube_node_labels{label_workload=~\"frontend|argocd\"}) * 0.0228) / sum(kube_node_status_allocatable{resource=\"memory\"}) * 1024 * 1024 * 1024)",
          "legendFormat": "{{ namespace }}",
          "refId": "A"
