      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(kube_node_labels{label_workload=~\"control-plane|monitoring\"} * 0.0456\nor\nkube_node_labels{label_workload=~\"frontend|argocd\"} * 0.0228) * 730",
          "legendFormat": "{{ label_workload }} — {{ node }}",
          "refId": "A"
        }
      ],
      "title": "Estimated Monthly Cost per Node",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 300,
      "title": "Cost per Namespace",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Estimated CPU cost per namespace — proportional share of total cluster cost based on CPU usage.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "USD/hour",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["lastNotNull", "mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (namespace) (rate(container_cpu_usage_seconds_total{container!=\"\", container!=\"POD\"}[1h])) * on() group_left() ((count(kube_node_labels{label_workload=~\"control-plane|monitoring\"}) * 0.0456 + count(kube_node_labels{label_workload=~\"frontend|argocd\"}) * 0.0228) / sum(kube_node_status_allocatable{resource=\"cpu\"}))",
          "legendFormat": "{{ namespace }}",
          "refId": "A"
        }
      ],
      "title": "Estimated CPU Cost per Namespace (hourly)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Estimated memory cost per namespace — proportional share of total cluster cost based on memory usage.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "USD/hour",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
