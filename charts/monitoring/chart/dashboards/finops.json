  "description": "FinOps cost visibility — workload cost per namespace, node cost breakdown, and resource efficiency metrics. Uses static EC2 on-demand pricing for eu-west-1.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Cost Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Estimated monthly cluster cost based on EU-West-1 on-demand pricing: t3.medium=$0.0456/hr, t3.small=$0.0228/hr.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#6ed0e0" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background_gradient",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": true,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(\n  count(kube_node_labels{label_workload=~\"control-plane|monitoring\"}) * 0.0456\n  +\n  count(kube_node_labels{label_workload=~\"frontend|argocd\"}) * 0.0228\n) * 730",
          "legendFormat": "Monthly Total",
          "refId": "A"
        }
      ],
      "title": "Estimated Monthly Cost (All Nodes)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Current total hourly cost across all running EC2 nodes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#73bf69" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "green", "value": null } ]
          },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background_gradient",
