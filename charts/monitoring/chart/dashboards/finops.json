      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(kube_node_labels{label_workload=~\"control-plane|monitoring\"}) * 0.0456 + count(kube_node_labels{label_workload=~\"frontend|argocd\"}) * 0.0228",
          "legendFormat": "Hourly Total",
          "refId": "A"
        }
