          "logGroups": [
            { "arn": "arn:aws:logs:us-east-1:771826808455:log-group:/aws/lambda/nextjs-acm-dns-validation-development", "name": "/aws/lambda/nextjs-acm-dns-validation-development", "accountId": "771826808455" },
