    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "description": "Live stream of the self-healing agent Lambda execution. Shows tool discovery, Bedrock iterations, tool invocations, and remediation reports in real time.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
          "expression": "fields @timestamp, @message, @logStream\n| filter @message like /level/\n| sort @timestamp desc\n| limit 200",
          "id": "",
          "logGroups": [
            { "arn": "arn:aws:logs:eu-west-1:771826808455:log-group:/aws/lambda/self-healing-dev-agent", "name": "/aws/lambda/self-healing-dev-agent", "accountId": "771826808455" }
          ],
          "queryMode": "Logs",
          "refId": "A",
          "region": "eu-west-1",
          "statsGroups": []
        }
      ],
      "title": "Agent Lambda — Live Execution Log",
      "type": "logs"
    },
    {
